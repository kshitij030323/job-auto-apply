# === LLM API (OpenAI-compatible — works with NVIDIA NIM, DashScope, OpenAI, etc.) ===
# Required for AI-powered form filling, resume tailoring, and cover letters
# Default: NVIDIA NIM with Qwen 3.5 122B
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=qwen/qwen3.5-122b-a10b

# === Google Sheets (for application tracking) ===
GOOGLE_SHEETS_CREDS_FILE=credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id

# === LinkedIn Credentials (optional — needed for LinkedIn Easy Apply) ===
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# === Your Details (used to auto-fill application forms) ===
# You can also set these interactively by running 'setup' inside the bot
YOUR_NAME=Your Full Name
YOUR_PHONE=+91XXXXXXXXXX
YOUR_EMAIL=your_email@example.com
YOUR_LOCATION=Bengaluru, India

# === Resume ===
# RESUME_PATH: path to your actual PDF resume (uploaded to job portals)
RESUME_PATH=./my_resume.pdf
# BASE_RESUME_TEXT_PATH: plain-text version of your resume (used by AI to tailor)
BASE_RESUME_TEXT_PATH=./base_resume.txt

# === Playwright ===
HEADLESS=false
SLOW_MO=800
